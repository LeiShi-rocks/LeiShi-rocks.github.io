<script>
/* Auto-assign colors to topic label classes from a fixed palette, keyed by label name. */
(function () {
  var PALETTE = [
    { bg: '#fff8e1', color: '#6d4c00', border: '#ffd54f' },
    { bg: '#e8f5e9', color: '#1b5e20', border: '#a5d6a7' },
    { bg: '#fce4ec', color: '#880e4f', border: '#f48fb1' },
    { bg: '#e8eaf6', color: '#283593', border: '#9fa8da' },
    { bg: '#fff3e0', color: '#bf360c', border: '#ffcc80' },
    { bg: '#e0f2f1', color: '#004d40', border: '#80cbc4' },
    { bg: '#f3e5f5', color: '#4a148c', border: '#ce93d8' },
    { bg: '#e3f2fd', color: '#0d47a1', border: '#90caf9' },
    { bg: '#fafafa', color: '#424242', border: '#bdbdbd' },
    { bg: '#f1f8e9', color: '#33691e', border: '#aed581' },
    { bg: '#e0f7fa', color: '#006064', border: '#80deea' },
    { bg: '#fff9c4', color: '#f57f17', border: '#fff176' },
  ];
  function hash(s) {
    var h = 0;
    for (var i = 0; i < s.length; i++) h = (Math.imul(31, h) + s.charCodeAt(i)) | 0;
    return Math.abs(h);
  }
  var seen = new Set();
  var css = '';
  document.querySelectorAll('.pub-label-topic').forEach(function (el) {
    el.classList.forEach(function (cls) {
      if (cls !== 'pub-label-topic' && cls.startsWith('pub-label-') && !seen.has(cls)) {
        seen.add(cls);
        var p = PALETTE[hash(cls) % PALETTE.length];
        css += '.' + cls + '{background:' + p.bg + ';color:' + p.color + ';border-color:' + p.border + '}';
      }
    });
  });
  if (css) { var s = document.createElement('style'); s.textContent = css; document.head.appendChild(s); }
})();

(function () {
  var activeTopics = new Set();
  var activeVenues = new Set();
  var sortOrder = 'desc';

  function applyFiltersAndSort() {
    var entries = Array.from(document.querySelectorAll('.pub-entry'));
    var shown = 0;
    entries.forEach(function (e) {
      var topics = e.dataset.topics.split(' ');
      var vtype = e.dataset.venueType;
      var topicOk = activeTopics.size === 0 || topics.some(function (t) { return activeTopics.has(t); });
      var venueOk = activeVenues.size === 0 || activeVenues.has(vtype);
      if (topicOk && venueOk) { e.classList.remove('hidden'); shown++; }
      else { e.classList.add('hidden'); }
    });
    entries.sort(function (a, b) {
      var ya = parseInt(a.dataset.year) || 0;
      var yb = parseInt(b.dataset.year) || 0;
      return sortOrder === 'desc' ? yb - ya : ya - yb;
    });
    var list = document.getElementById('pub-list');
    entries.forEach(function (e) { list.appendChild(e); });
    var el = document.getElementById('pub-count');
    if (el) el.textContent = shown + ' paper' + (shown !== 1 ? 's' : '') + ' shown';
  }

  function setupFilterGroup(attrName, activeSet) {
    document.querySelectorAll('[data-filter-type="' + attrName + '"]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var val = btn.dataset.value;
        if (val === 'all') {
          activeSet.clear();
          document.querySelectorAll('[data-filter-type="' + attrName + '"]').forEach(function (b) { b.classList.remove('active'); });
          btn.classList.add('active');
        } else {
          document.querySelector('[data-filter-type="' + attrName + '"][data-value="all"]').classList.remove('active');
          if (activeSet.has(val)) { activeSet.delete(val); btn.classList.remove('active'); }
          else { activeSet.add(val); btn.classList.add('active'); }
          if (activeSet.size === 0) {
            document.querySelector('[data-filter-type="' + attrName + '"][data-value="all"]').classList.add('active');
          }
        }
        applyFiltersAndSort();
      });
    });
  }

  document.addEventListener('DOMContentLoaded', function () {
    setupFilterGroup('topic', activeTopics);
    setupFilterGroup('venue', activeVenues);
    document.querySelectorAll('.pub-sort-btn').forEach(function (btn) {
      btn.addEventListener('click', function () {
        sortOrder = btn.dataset.sort;
        document.querySelectorAll('.pub-sort-btn').forEach(function (b) { b.classList.remove('active'); });
        btn.classList.add('active');
        applyFiltersAndSort();
      });
    });
    applyFiltersAndSort();
  });
})();
</script>
~~~
